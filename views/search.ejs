<div class="deck two-col">
  <section class="module">
    <header class="module-head"><h2>Обзор площадки</h2><span><%= results.length %> результатов</span></header>
    <div class="module-body">
      <div class="search-box"><input class="input" placeholder="Каталог скрыт" disabled /></div>
      <% if (!results.length) { %>
        <div class="empty">Треки скрыты с сайта. Эта страница пока работает как обзор без каталога.</div>
      <% } else { %>
        <div class="track-list">
          <% results.forEach(t => { %>
            <article class="track-unit">
              <div class="cover"><img src="<%= t.cover %>" alt=""></div>
              <div class="meta"><div class="t"><a href="/track/<%= t.id %>"><%= t.title %></a></div><div class="a"><%= t.artist %> • <%= t.genre %></div></div>
              <div class="right">
                <span class="pill"><%= t.duration %></span>
                <button class="likebtn <%= t.isLiked ? 'liked' : '' %>" data-like-id="<%= t.id %>" aria-label="Лайк">❤</button>
                <button class="iconbtn" data-play='<%= JSON.stringify({id:t.id, title:t.title, artist:t.artist, artistId:t.artistId, cover:t.cover, audio:t.audio}) %>' title="Play">▶</button>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>

  <section class="module">
    <header class="module-head"><h2>Статус</h2></header>
    <div class="module-body">
      <div class="chipline">
        <a class="chip" href="/">Главная</a>
        <a class="chip" href="/profile">Профиль</a>
        <a class="chip" href="/playlists">Подборки</a>
      </div>
    </div>
  </section>
</div>
